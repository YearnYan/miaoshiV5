:root{--bg-main: #050806;--bg-panel: #11151a;--bg-elev: #171a1f;--text-primary: #e8ffe8;--text-secondary: #6e7a72;--text-muted: #4a524e;--accent-main: #1edc74;--accent-glow: rgba(30, 220, 116, .4);--state-warning: #f5a623;--state-danger: #ff4d4f;--state-info: #4a84ff;--border-subtle: #27302b;--border-accent: rgba(30, 220, 116, .3);--overlay-dim: rgba(0, 0, 0, .8);--font-mono: JetBrains Mono, Menlo, Consolas, monospace;--font-sans: PingFang SC, Microsoft YaHei, sans-serif}view,text,button,input,image{box-sizing:border-box}.pixel-screen{position:relative;width:750rpx;min-height:1624rpx;background:var(--bg-main);overflow:hidden}.pixel-bg{position:absolute;left:0;top:0;width:750rpx;height:1624rpx;z-index:1;pointer-events:none}.pixel-layer{position:relative;z-index:3;width:750rpx;min-height:1624rpx}.pixel-hotspot{position:absolute;z-index:5;background:transparent}page{background:var(--bg-main);color:var(--text-primary);font-family:var(--font-sans)}.app-shell{min-height:100vh;background:var(--bg-main)}.content-padding{padding:0 30rpx}.panel{background:var(--bg-panel);border:1px solid var(--border-subtle);border-radius:24rpx}.mono{font-family:var(--font-mono)}.muted{color:var(--text-secondary)}.danger{color:var(--state-danger)}.warning{color:var(--state-warning)}.success{color:var(--accent-main)}.overlay-text,.overlay-row{display:none!important}
page{--status-bar-height:25px;--top-window-height:0px;--window-top:0px;--window-bottom:0px;--window-left:0px;--window-right:0px;--window-magin:0px}[data-c-h="true"]{display: none !important;}